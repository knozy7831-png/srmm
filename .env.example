# Copy to .env and fill in. NEVER commit the real .env.

# Anthropic API key (required for document generation)
ANTHROPIC_API_KEY=your_api_key_here

# JWT signing secret. REQUIRED in production (server refuses to start without it).
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Server port (optional, default 3000)
PORT=3000

# Set to "production" on a live server (enables strict CORS, trust proxy, hides error details)
NODE_ENV=development

# Allowed front-end origin in production (used for CORS when NODE_ENV=production)
FRONTEND_URL=https://your-domain.example

# Optional single admin account via env (bypasses the database)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional: custom SQLite database path (default ./cologic.db)
# DB_PATH=./cologic.db
